# Database connection string (asyncpg driver)
# Note: Use 'db' instead of 'localhost' if running inside Docker Compose
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/b2b_core

# Redis connection for WebSockets/Caching
REDIS_URL=redis://localhost:6379/0

# JWT Security settings
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30